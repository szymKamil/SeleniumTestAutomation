pipeline {
    agent any

    environment {
        DOCKER_HOST = 'tcp://host.docker.internal:2375'
    }

    tools {
        maven 'Maven' // nazwa z Manage Jenkins → Global Tool Configuration
        jdk 'JDK'
    }


    options {
        skipDefaultCheckout()
    }
    stages {
        stage('Clean') {
            steps {
                // Teraz to zadziała jako pierwsze i naprawi uszkodzony folder
                echo "Czyszczenie przestrzeni roboczej..."
                cleanWs()
            }
        }
        stage('Docker test') {
            steps {
                sh 'docker ps'
            }
        }

        stage('Check Selenium Grid') {
            steps {
                script {
                    // Sprawdzamy czy Grid żyje, zanim pobierzemy kod
                    def response = sh(script: "curl -s -o /dev/null -w '%{http_code}' http://selenium-hub-env:4444/wd/hub/status", returnStdout: true).trim()
                    if (response != '200') {
                        error "Selenium Grid nie działa! Uruchamiam go osobno w Dockerze."
                        sh '''
                                docker compose -p test-env start
                           '''
                    } else {
                        echo "✅ Grid OK — kontynuuję testy."
                    }
                }
            }
        }

        stage('Checkout') {
            steps {
                echo "Pobieranie kodu z repozytorium..."
                // Tutaj ręcznie pobieramy kod do CZYSTEGO folderu
                git branch: 'master',
                        url: 'https://github.com/szymKamil/SeleniumTestAutomation.git',
                        credentialsId: 'github-token'
            }
        }

        stage('Compile Maven') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Build and Run Tests') {
            steps {
                echo 'Uruchamianie testów TestNG...'
                sh 'mvn clean test -DsuiteXmlFile=src/test/java/Selenium/BoniGarcia/BGtestng.xml'
            }
        }


        stage('Allure Report') {
            steps {
                allure([
                        includeProperties: false,
                        jdk: '',
                        results: [[path: 'target/allure-results']]
                ])
            }
        }
    }



    post {
        always {
            echo 'Pipeline zakończony — czyszczenie'
            script {
                try {
                    echo  "Zatrzymuję środowisko gridowe"
                    sh '''
                      docker compose -p test-env stop
                    '''
                } catch (Exception e) {
                    echo "Nie udało się zatrzymać wszystkich kontenerów: ${e.message}"
                    echo "Kończe testy"
                }
            }
        }
        success {
            echo '✅ Testy przeszły pomyślnie!'
        }
        failure {
            echo '❌ Błąd testów!'
        }
    }

}


