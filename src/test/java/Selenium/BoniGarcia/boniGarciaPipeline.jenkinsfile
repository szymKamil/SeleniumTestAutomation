pipeline {
    agent any

    tools {
        maven 'Maven' // nazwa z Manage Jenkins → Global Tool Configuration
        jdk 'JDK'
    }

    stages {
        stage('Run Selenium grid and nodes') {
            steps {
                script {
                    def gridStatus = checkGridStatus('http://localhost:4444/wd/hub/status')
                    if (!gridStatus) {
                        echo "Selenium Grid nie działa. Uruchamiam Grid i nody..."
                        startSeleniumGrid()
                    } else {
                        echo "Selenium Grid działa poprawnie."
                    }
                }
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'jenkins-integration',
                        url: 'https://github.com/szymKamil/SeleniumTestAutomation.git',
                        credentialsId: 'github-token'
            }
        }

        stage('Compile Maven') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Build and Run Tests') {
            steps {
                echo 'Uruchamianie testów TestNG...'
                sh 'mvn clean test -DsuiteXmlFile=src/test/java/Selenium/BoniGarcia/BGtestng.xml'
            }
        }

        stage('Report') {
            steps {
                echo 'Zbieranie raportów testów...'
                junit '**/target/surefire-reports/*.xml'
            }
        }
    }

    post {
        always {
            echo 'Pipeline zakończony — czyszczenie'
            script {
                try {
                    sh '''
                        docker stop selenium-hub || true
                        docker stop chrome-node || true
                        docker stop chrome-node-2 || true
                        docker stop firefox-node || true
                        docker stop edge-node || true
                    '''
                } catch (Exception e) {
                    echo "Nie udało się zatrzymać wszystkich kontenerów: ${e.message}"
                }
            }
        }
        success {
            echo '✅ Testy przeszły pomyślnie!'
        }
        failure {
            echo '❌ Błąd testów!'
        }
    }
}

// --------------------------------------------------
// Funkcje pomocnicze (muszą być poniżej lub powyżej, ale w tym samym pliku)
def checkGridStatus(String gridUrl) {
    try {
        def response = sh(script: "curl -s -o /dev/null -w '%{http_code}' ${gridUrl}", returnStdout: true).trim()
        return response == '200'
    } catch (Exception e) {
        echo "Błąd podczas sprawdzania statusu Grid: ${e.message}"
        return false
    }
}

def startSeleniumGrid() {
    try {
        sh '''
            docker start selenium-hub || docker run -d -p 4444:4444 --name selenium-hub selenium/hub:latest
            docker start chrome-node || docker run -d --name chrome-node --link selenium-hub:hub selenium/node-chrome:latest
            docker start chrome-node-2 || docker run -d --name chrome-node-2 --link selenium-hub:hub selenium/node-chrome:latest
            docker start firefox-node || docker run -d --name firefox-node --link selenium-hub:hub selenium/node-firefox:latest
            docker start edge-node || docker run -d --name edge-node --link selenium-hub:hub selenium/node-edge:latest
        '''
        sleep(time: 10, unit: 'SECONDS')
        echo "Selenium Grid uruchomiony."
    } catch (Exception e) {
        error "Nie udało się uruchomić Selenium Grid: ${e.message}"
    }
}
